{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "outDir": "./.tsbuild/node",
    "tsBuildInfoFile": "./.tsbuild/tsconfig.node.tsbuildinfo",
    "strict": true
  },
  "include": ["vite.config.ts", "src/types.ts", "src/ai/**/*.ts"]
}
